.analysis-tool {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: #fff;
    position: relative;

    &__tabs {
        display: flex;
        gap: 8px;
        padding: 12px;
        background: #fff;
        border-bottom: 1px solid #eee;
        overflow-x: auto;

        &::-webkit-scrollbar {
            display: none;
        }
    }

    &__tab {
        padding: 8px 16px;
        border: 1px solid #dcdcdc;
        background: #fff;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
        cursor: pointer;
        color: #333;

        &--active {
            background: #4a90e2;
            color: #fff;
            border-color: #4a90e2;
        }
    }

    &__content {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 20px;
        gap: 20px;
        overflow-y: auto;
    }

    &__header-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    &__status-badge {
        padding: 8px 20px;
        background: #f0f0f0;
        border-radius: 4px;
        font-weight: bold;
        font-size: 14px;

        &.active {
            background: #4caf50;
            color: white;
            animation: blink 1s infinite;
        }
    }

    &__digit-grid {
        display: flex;
        justify-content: space-between;
        padding: 20px 0;
        border-bottom: 1px solid #eee;

        .digit-circle {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            width: 60px;
            position: relative;

            &__number {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                border: 2px solid #ddd;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: bold;
                font-size: 16px;
            }

            &__percent {
                font-size: 11px;
                color: #666;
            }

            &__label {
                font-size: 10px;
                color: #999;
                white-space: nowrap;
                position: absolute;
                bottom: -20px;
            }

            &.most .digit-circle__number {
                background: #4caf50;
                color: white;
                border-color: #4caf50;
            }

            &.second-most .digit-circle__number {
                background: #2196f3;
                color: white;
                border-color: #2196f3;
            }

            &.least .digit-circle__number {
                background: #f44336;
                color: white;
                border-color: #f44336;
            }

            &.second-least .digit-circle__number {
                background: #ff9800;
                color: white;
                border-color: #ff9800;
            }
        }
    }

    &__iframe-wrapper {
        flex: 1;
        min-height: 500px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    &__iframe {
        width: 100%;
        height: 100%;
        border: none;
    }

    &__risk-disclaimer {
        position: absolute;
        bottom: 20px;
        left: 20px;
        background: #ffd700;
        color: #000;
        padding: 6px 12px;
        font-weight: bold;
        border-radius: 4px;
        font-size: 12px;
        z-index: 10;
    }
}

@keyframes blink {
    0% { opacity: 1; }
    50% { opacity: 0.6; }
    100% { opacity: 1; }
}
